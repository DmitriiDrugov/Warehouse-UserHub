    "db:seed": "tsx lib/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "drizzle-orm": "^0.36.4",
    "next": "15.0.3",
    "node-sql-parser": "^5.3.4",
    "postgres": "^3.4.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0-beta.5",
    "@types/node": "^22.9.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.1",
    "tailwindcss": "^4.0.0-beta.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
