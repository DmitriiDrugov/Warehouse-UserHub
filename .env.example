# ============================================================
# Warehouse UserHub — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ============================================================

# ---- Supabase (client-visible) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ---- Supabase (server-only) ----
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ---- Database connections ----
# DATABASE_URL: full-privilege connection used by app + drizzle migrations.
#   For Supabase: Project Settings → Database → Connection string (URI, transaction pooler 6543 or direct 5432).
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres

# DATABASE_URL_READONLY: connection restricted to the `nl_query_reader` role (created in migration 0001).
#   Used only by lib/ai/nl-sql to execute LLM-generated SELECTs. NEVER reuse the read-write connection here.
DATABASE_URL_READONLY=postgresql://nl_query_reader:READONLY_PASSWORD@HOST:5432/postgres

# ---- LLM ----
# LLM_PROVIDER: "openrouter" | "anthropic"
LLM_PROVIDER=openrouter
# LLM_MODEL: provider-specific model id.
#   OpenRouter examples: "anthropic/claude-3-haiku", "meta-llama/llama-3.1-8b-instruct:free"
#   Anthropic examples: "claude-haiku-4-5-20251001", "claude-sonnet-4-6"
LLM_MODEL=anthropic/claude-3-haiku
LLM_API_KEY=YOUR_LLM_API_KEY
# Optional: base URL override (defaults: https://openrouter.ai/api/v1 or https://api.anthropic.com/v1)
LLM_BASE_URL=

# ---- Cron / scheduled jobs ----
# Random secret protecting /api/cron/* route handlers. Pass as `Authorization: Bearer <secret>`.
CRON_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ---- OAuth / SSO (optional — corporate IdP can be plugged in later) ----
# Comma-separated list of Supabase auth providers to expose in the login UI (e.g. "azure,google").
# Empty/unset = email+password only.
OAUTH_PROVIDERS=

# ---- Operational tuning ----
# Statement timeout (ms) applied to NL-SQL read-only queries.
NL_SQL_STATEMENT_TIMEOUT_MS=5000
# Forced LIMIT injected into LLM-generated SELECTs.
NL_SQL_MAX_ROWS=200
# Days after which an unused user_access row is considered dormant (anomaly detection §6.2).
ANOMALY_DORMANT_DAYS=90
# Offboarding SLA window in hours before active access on an offboarded user escalates (§5).
OFFBOARDING_SLA_HOURS=24
# Days after which a pending AI proposal is automatically expired (keeps the queue clean).
PROPOSAL_EXPIRY_DAYS=30
